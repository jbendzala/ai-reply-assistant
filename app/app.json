{
  "expo": {
    "name": "ReplyGen",
    "slug": "ai-reply-assistant",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/ReplyGen_logo_text.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/ReplyGen_logo_text.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.replygen.app"
    },
    "android": {
      "package": "com.replygen.app",
      "versionCode": 3,
      "adaptiveIcon": {
        "foregroundImage": "./assets/ReplyGen_logo_text.png",
        "backgroundColor": "#0A0A0F"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION",
        "android.permission.FOREGROUND_SERVICE_SPECIAL_USE",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "../modules/screen-capture/plugin/withScreenCapture"
    ],
    "scheme": "replygen",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "967015e8-f985-447b-a3a4-c9b28f8a0146"
      }
    },
    "owner": "bendzalaj"
  }
}
